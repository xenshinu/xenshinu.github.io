---
type Props = {
  to: string;
  title?: string;
};

const { to, title = "Redirecting" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <title>{title}</title>
    <link rel="canonical" href={to} />
  </head>
  <body>
    <p>Redirecting to <a href={to}>{to}</a>.</p>
  </body>
</html>
