---
import LogoBadge from "./LogoBadge.astro";
import { profile } from "@data/profile";

const announcement = "Open to full-time role in 2027!!!";
---

<section class="smi-shell hero" aria-label="Xueshen-SMI status header">
  <div class="hero-topline">
    <span>XUESHEN-SMI 1.0</span>
    <span>{new Intl.DateTimeFormat("en", { weekday: "short", month: "short", day: "numeric", year: "numeric" }).format(new Date())}</span>
  </div>

  <div class="smi-frame">
    <div class="smi-row smi-title-row">
      <div>
        <p class="eyebrow">Research Runtime</p>
        <h1>{profile.name}</h1>
        <p class="name-alt">{profile.nameAlt}</p>
      </div>
      <img class="avatar" src={profile.avatar} alt="Xueshen Liu profile photo" />
    </div>

    <div class="smi-grid">
      <div class="smi-cell">
        <span class="field">Driver version</span>
        <strong>PhD-0.4.9</strong>
      </div>
      <div class="smi-cell">
        <span class="field">Mode</span>
        <strong>Elastic LLM infra</strong>
      </div>
      <div class="smi-cell">
        <span class="field">Namespace</span>
        <strong>UMICH CSE</strong>
      </div>
      <div class="smi-cell">
        <span class="field">Location</span>
        <strong>{profile.location}</strong>
      </div>
    </div>

    <p class="intro">
      {profile.intro}
    </p>

    <aside class="smi-announcement" aria-label="announcement">
      <span>IMPORTANT</span>
      <strong>{announcement}</strong>
    </aside>

    <div class="badge-line" aria-label="focus stack">
      {profile.focusBadges.map((badge) => <LogoBadge badge={badge} />)}
    </div>

    <nav class="hero-actions" aria-label="primary links">
      <a class="email-action" href="mailto:liuxs@umich.edu">Email: liuxs AT umich.edu</a>
      <a href={profile.scholar}>Publications</a>
      <a href={profile.cv}>CV</a>
      <a href={profile.github}>GitHub</a>
    </nav>
  </div>
</section>
