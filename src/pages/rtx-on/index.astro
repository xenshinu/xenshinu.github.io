---
import { readdirSync } from "node:fs";
import path from "node:path";
import BaseLayout from "@layouts/BaseLayout.astro";
import SiteNav from "@components/SiteNav.astro";

const galleryDir = path.resolve("./public/assets/images/gallery");
const files = readdirSync(galleryDir)
  .filter((file) => /\.(jpe?g|png|webp|gif|avif)$/i.test(file))
  .sort();

function tiltFor(name: string) {
  let hash = 0;
  for (let i = 0; i < name.length; i += 1) {
    hash = (hash * 31 + name.charCodeAt(i)) | 0;
  }
  return ((Math.abs(hash) % 60) - 30) / 10;
}

function captionFor(name: string) {
  return name.replace(/\.[^.]+$/, "").replace(/[-_]+/g, " ");
}

const photos = files.map((file) => ({
  src: `/assets/images/gallery/${file}`,
  alt: captionFor(file),
  caption: captionFor(file),
  tilt: tiltFor(file)
}));
---

<BaseLayout title="RTX on | Xueshen Liu">
  <main class="page-shell">
    <SiteNav active="rtx" />
    <section class="rtx-shell smi-shell" aria-label="RTX-on gallery">
      <div class="window-bar">
        <span>RTX / ray-traced memories</span>
        <span><span class="smi-count">{photos.length}</span> frames lit</span>
      </div>
      <div class="rtx-wall" role="list">
        {photos.map((photo) => (
          <figure
            class="rtx-tile"
            role="listitem"
            style={`--tilt: ${photo.tilt}deg;`}
          >
            <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" />
            <figcaption>{photo.caption}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
