---
import BaseLayout from "@layouts/BaseLayout.astro";
import SiteNav from "@components/SiteNav.astro";
import SmiHeader from "@components/SmiHeader.astro";
import TraceGrid from "@components/TraceGrid.astro";
import ProcessWindow from "@components/ProcessWindow.astro";
import { profile } from "@data/profile";

const hostProcesses = [
  {
    pid: "12",
    time: "Apr 2026",
    command: "Foundry arXiv and code release",
    detail: "Template-based CUDA graph context materialization for fast LLM serving cold start.",
    href: "https://arxiv.org/abs/2604.06664"
  },
  {
    pid: "11",
    time: "Feb 2026",
    command: "Citadel Securities QR internship",
    detail: "Incoming Quantitative Researcher Intern for summer 2026 in Miami.",
    href: "https://www.citadelsecurities.com/"
  },
  {
    pid: "10",
    time: "Dec 2025",
    command: "RLBoost accepted to NSDI'26",
    detail: "Wrapped up Student Researcher work with Systems Research @ Google.",
    href: "https://arxiv.org/abs/2510.19225"
  },
  {
    pid: "09",
    time: "Jul 2025",
    command: "Plato accepted to COLM'25",
    detail: "Plan-to-decode work for LLM inference will appear at COLM.",
    href: "https://arxiv.org/abs/2402.12280"
  },
  {
    pid: "08",
    time: "May 2025",
    command: "CAKE accepted to ICML'25",
    detail: "Long-context KV-cache prefill optimization work heading to ICML.",
    href: "https://arxiv.org/abs/2410.03065"
  },
  {
    pid: "07",
    time: "May 2025",
    command: "Systems Research @ Google",
    detail: "Started distributed RL systems work for LLMs in Seattle.",
    href: "https://techsysinfra.google/research/"
  },
  {
    pid: "06",
    time: "Dec 2024",
    command: "LTE NeurIPS spotlight",
    detail: "Structured sparsity and sparse FFN kernel work presented at NeurIPS.",
    href: "https://arxiv.org/abs/2402.06126"
  },
  {
    pid: "05",
    time: "Oct 2024",
    command: "mm2-gb ACM BCB oral",
    detail: "GPU-accelerated minimap2 work selected as an oral presentation.",
    href: "https://www.biorxiv.org/content/10.1101/2024.03.23.586366v2.abstract"
  },
  {
    pid: "04",
    time: "Sep 2024",
    command: "CSE 589 Graduate Student Instructor",
    detail: "Started teaching Advanced Computer Networks at the University of Michigan."
  },
  {
    pid: "03",
    time: "May 2024",
    command: "General Motors CAV Lab",
    detail: "Started research internship on latency-tolerant edge/cloud positioning systems."
  },
  {
    pid: "02",
    time: "Aug 2021",
    command: "Roger King Scholarship",
    detail: "College of Engineering, University of Michigan."
  },
  {
    pid: "01",
    time: "Aug 2019",
    command: "Robomaster Final Competition",
    detail: "Runner-up Team and Grand Prize."
  }
];
---

<BaseLayout title="Xueshen Liu | XUESHEN-SMI">
  <main class="page-shell">
    <SiteNav active="home" />
    <SmiHeader />
    <ProcessWindow />
    <TraceGrid />

    <section class="content-grid">
      <div class="content-panel">
        <h2>Host Processes</h2>
        <div class="host-process-table">
          <div class="host-process-head" aria-hidden="true">
            <span>PID</span>
            <span>TIME</span>
            <span>COMMAND</span>
          </div>
          <div class="host-process-body">
            {hostProcesses.map((process) => (
              process.href ? (
                <a class="host-process-row" href={process.href}>
                  <span class="mono">{process.pid}</span>
                  <span>{process.time}</span>
                  <span>
                    <strong>{process.command}</strong>
                    <small>{process.detail}</small>
                  </span>
                </a>
              ) : (
                <div class="host-process-row">
                  <span class="mono">{process.pid}</span>
                  <span>{process.time}</span>
                  <span>
                    <strong>{process.command}</strong>
                    <small>{process.detail}</small>
                  </span>
                </div>
              )
            ))}
          </div>
        </div>
      </div>

      <aside class="content-panel">
        <h2>Runtime Stack</h2>
        <div class="chip-list">
          {profile.stack.map((tool) => <span class="chip">{tool}</span>)}
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
