---
import BaseLayout from "@layouts/BaseLayout.astro";
import SiteNav from "@components/SiteNav.astro";
import SmiHeader from "@components/SmiHeader.astro";
import TraceGrid from "@components/TraceGrid.astro";
import ProcessWindow from "@components/ProcessWindow.astro";
import { profile } from "@data/profile";

const hostProcessTypes = {
  talk: { token: "TALK", label: "Talk" },
  conference: { token: "CONF", label: "Conference" },
  publication: { token: "PUB", label: "Publication" },
  role: { token: "ROLE", label: "New role" },
  award: { token: "AWARD", label: "Award" }
} as const;

type HostProcessType = keyof typeof hostProcessTypes;
type HostProcess = {
  pid: string;
  time: string;
  type: HostProcessType;
  command: string;
  detail: string;
  href?: string;
};

const hostProcesses = [
  {
    pid: "17",
    time: "May 2026",
    type: "publication",
    command: "Dr. Post-training paper and code release",
    detail: "Excited to share Dr. Post-Training! We released the paper and code for our data-regularization framework on LLM post-training.",
    href: "https://arxiv.org/abs/2605.07063"
  },
  {
    pid: "16",
    time: "May 2026",
    type: "talk",
    command: "Invited talk for Amazon Rufus AI lab",
    detail: "Excited to give an invited talk, Towards Instantaneous Elasticity in LLM Infrastructure: From Harvesting Preemptible Resources to a General Cold-Start-Free Serving Stack."
  },
  {
    pid: "15",
    time: "May 2026",
    type: "conference",
    command: "Present RLBoost at NSDI'26",
    detail: "Excited to present RLBoost on NSDI'26 and meet talented researchers working on network and systems!",
    href: "https://www.usenix.org/conference/nsdi26/technical-sessions"
  },
  {
    pid: "14",
    time: "Apr 2026",
    type: "publication",
    command: "Foundry paper and code release",
    detail: "Super excited to share Foundry! It is our recent work for fast LLM serving cold start via template-based CUDA graph context materialization.",
    href: "https://arxiv.org/abs/2604.06664"
  },
  {
    pid: "13",
    time: "Feb 2026",
    type: "role",
    command: "Incoming Citadel Securities QR internship",
    detail: "Happy to share that I will work at Citadel Securities as Quantitative Researcher Intern for summer 2026 in Miami.",
    href: "https://www.citadelsecurities.com/"
  },
  {
    pid: "12",
    time: "Dec 2025",
    type: "publication",
    command: "RLBoost accepted to NSDI'26",
    detail: "Happy to share that RLBoost has been accepted to NSDI'26. Wrapped up Student Researcher work with Systems Research @ Google! Huge thanks to all my collaborators.",
    href: "https://arxiv.org/abs/2510.19225"
  },
  {
    pid: "11",
    time: "Jul 2025",
    type: "publication",
    command: "Plato accepted to COLM'25",
    detail: "Happy to share that Plato has been accepted to COLM'25. This is our work on planning and parallel decoding for efficient LLM inference.",
    href: "https://arxiv.org/abs/2402.12280"
  },
  {
    pid: "10",
    time: "May 2025",
    type: "publication",
    command: "CAKE accepted to ICML'25",
    detail: "Excited to share that CAKE has been accepted to ICML'25! It is our work on reducing long-context prefill latency by overlapping KV-cache computation and loading.",
    href: "https://arxiv.org/abs/2410.03065"
  },
  {
    pid: "09",
    time: "May 2025",
    type: "role",
    command: "Systems Research @ Google Student Researcher Internship",
    detail: "Excited to join Systems Research @ Google as a Student Researcher in Seattle, working on distributed RL systems for LLMs.",
    href: "https://techsysinfra.google/research/"
  },
  {
    pid: "08",
    time: "Dec 2024",
    type: "conference",
    command: "LTE NeurIPS spotlight",
    detail: "Honored to share that LTE was presented as a Spotlight at NeurIPS'24. This work explores structured sparsity and efficient sparse FFN kernels for LLMs.",
    href: "https://arxiv.org/abs/2402.06126"
  },
  {
    pid: "07",
    time: "Oct 2024",
    type: "conference",
    command: "mm2-gb ACM BCB oral",
    detail: "Happy to share that mm2-gb was selected as an Oral at ACM BCB'24. It is our work on GPU-accelerated minimap2 for long-read DNA mapping.",
    href: "https://www.biorxiv.org/content/10.1101/2024.03.23.586366v2.abstract"
  },
  {
    pid: "06",
    time: "Sep 2024",
    type: "role",
    command: "CSE 589 Graduate Student Instructor",
    detail: "Happy to start as Graduate Student Instructor for CSE 589 Advanced Computer Networks at the University of Michigan."
  },
  {
    pid: "05",
    time: "Aug 2024",
    type: "talk",
    command: "Invited talk for General Motors Research",
    detail: "Excited to give an invited talk, Scalable & Latency-tolerant Edge/Cloud Computing via Deep Factor Graph."
  },
  {
    pid: "04",
    time: "May 2024",
    type: "role",
    command: "General Motors CAV Lab Research Intern",
    detail: "Excited to intern in the Connected Autonomous Vehicle Lab at General Motors, working on latency-tolerant edge/cloud positioning systems."
  },
  {
    pid: "03",
    time: "May 2024",
    type: "talk",
    command: "Invited talk at AMD HPC Apps Knowledge Sync",
    detail: "Excited to give an invited talk on Minimap2-gigabases (mm2-gb) at AMD HPC Apps Knowledge Sync."
  },
  {
    pid: "02",
    time: "Aug 2021",
    type: "award",
    command: "Roger King Scholarship",
    detail: "Honored to receive the Roger King Scholarship from the College of Engineering at the University of Michigan."
  },
  {
    pid: "01",
    time: "Aug 2019",
    type: "award",
    command: "Robomaster Final Competition",
    detail: "Happy to share that our team won Runner-up Team and Grand Prize at the Robomaster Final Competition."
  }
] satisfies HostProcess[];
---

<BaseLayout title="Xueshen Liu | XUESHEN-SMI">
  <main class="page-shell">
    <SiteNav active="home" />
    <SmiHeader />
    <ProcessWindow />
    <TraceGrid />

    <section class="content-grid">
      <div class="content-panel">
        <h2>Host Processes</h2>
        <div class="host-process-table">
          <div class="host-process-head" aria-hidden="true">
            <span>PID</span>
            <span>TIME</span>
            <span>COMMAND</span>
          </div>
          <div class="host-process-body">
            {hostProcesses.map((process) => (
              process.href ? (
                <a class="host-process-row" href={process.href}>
                  <span class="mono">{process.pid}</span>
                  <span class="host-time">
                    <span>{process.time}</span>
                    <span class="host-type" data-type={process.type} aria-label={hostProcessTypes[process.type].label}>{hostProcessTypes[process.type].token}</span>
                  </span>
                  <span>
                    <strong>{process.command}</strong>
                    <small>{process.detail}</small>
                  </span>
                </a>
              ) : (
              <div class="host-process-row">
                <span class="mono">{process.pid}</span>
                <span class="host-time">
                  <span>{process.time}</span>
                  <span class="host-type" data-type={process.type} aria-label={hostProcessTypes[process.type].label}>{hostProcessTypes[process.type].token}</span>
                </span>
                <span>
                  <strong>{process.command}</strong>
                  <small>{process.detail}</small>
                  </span>
                </div>
              )
            ))}
          </div>
        </div>
      </div>

      <aside class="content-panel">
        <h2>Memory Heap</h2>
        <div class="chip-list">
          {profile.stack.map((tool) => <span class="chip">{tool}</span>)}
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
