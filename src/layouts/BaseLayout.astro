---
import "@styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Xueshen Liu",
  description = "LLM infrastructure, GPU parallel computing, and heterogeneous systems research."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/assets/images/web-logo.JPG" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-noise" aria-hidden="true"></div>
    <slot />
  </body>
</html>
